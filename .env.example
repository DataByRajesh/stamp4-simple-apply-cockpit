# Server-only Supabase credentials for the separate Stamp4 Simple Apply project.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared-secret deterrent. Use the same value for server and client header.
STAMP4_ACCESS_SECRET=replace-with-a-long-random-string

# Optional AI prose/source discovery.
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4.1-mini

CRON_SECRET=replace-with-a-second-long-random-string
RESEND_API_KEY=re_xxxxxxxxx
STAMP4_ALERT_EMAIL_TO=you@example.com
STAMP4_ALERT_EMAIL_FROM=Stamp4 Alerts <alerts@your-verified-domain.com>

# Optional recruiter contact lookup (Apollo.io free tier - ~50-100 enrichment credits/month).
# Results are cached in Supabase's contact_lookup_cache table for 90 days to conserve credits.
APOLLO_API_KEY=your-apollo-api-key-here
